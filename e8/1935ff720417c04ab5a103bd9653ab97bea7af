 EXISTS idx_quota_tracking_api_key_month ON quota_tracking(api_key_id, month);\n\n-- Enable Row Level Security (RLS)\nALTER TABLE api_keys ENABLE ROW LEVEL SECURITY;\nALTER TABLE usage_logs ENABLE ROW LEVEL SECURITY;\nALTER TABLE quota_tracking ENABLE ROW LEVEL SECURITY;\n\n-- RLS Policies\nCREATE POLICY \"Users can view own API keys\" ON api_keys\n    FOR SELECT USING (auth.uid() = user_id);\n\nCREATE POLICY \"Users can insert own API keys\" ON api_keys\n    FOR INSERT WITH CHECK (auth.uid() = user_id);\n\nCREATE POLICY \"Users can update own API keys\" ON api_keys\n    FOR UPDATE USING (auth.uid() = user_id);\n\nCREATE POLICY \"Users can delete own API keys\" ON api_keys\n    FOR DELETE USING (auth.uid() = user_id);\n\nCREATE POLICY \"Users can view own usage logs\" ON usage_logs\n    FOR SELECT USING (\n        EXISTS (\n            SELECT 1 FROM api_keys \n            WHERE api_keys.id = usage_logs.api_key_id \n            AND api_keys.user_id = auth.uid()\n        )\n    );\n\nCREATE POLICY \"Users can view own quota\" ON quota_tracking\n    FOR SELECT USING (\n        EXISTS (\n            SELECT 1 FROM api_keys \n            WHERE api_keys.id = quota_tracking.api_key_id \n            AND api_keys.user_id = auth.uid()\n        )\n    );\n\n-- Functions\nCREATE OR REPLACE FUNCTION increment_quota(p_api_key_id UUID, p_month DATE)\nRETURNS void AS $$\nBEGIN\n    INSERT INTO quota_tracking (api_key_id, month, requests_count)\n    VALUES (p_api_key_id, p_month, 1)\n    ON CONFLICT (api_key_id, month)\n    DO UPDATE SET \n        requests_count = quota_tracking.requests_count + 1,\n        updated_at = NOW();\nEND;\n$$ LANGUAGE plpgsql;\n\n-- Comments\nCOMMENT ON TABLE api_keys IS 'API keys for DevMemory Cloud access';\nCOMMENT ON TABLE usage_logs IS 'Logs of all API requests for monitoring and billing';\nCOMMENT ON TABLE quota_tracking IS 'Monthly quota usage tracking per API key';\n",
