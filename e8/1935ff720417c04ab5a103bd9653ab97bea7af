ai\"\nelif git ai version &>/dev/null 2>&1; then\n    GIT_AI_BIN=\"git ai\"\nfi\n\nif [ -n \"$GIT_AI_BIN\" ]; then\n    info \"Git AI is already installed\"\nelse\n    warn \"Git AI is not installed\"\n    read -p \"Install Git AI now? [Y/n] \" -n 1 -r\n    echo\n    if [[ ! $REPLY =~ ^[Nn]$ ]]; then\n        echo \"Installing Git AI...\"\n        curl -sSL https://usegitai.com/install.sh | bash\n        info \"Git AI installed\"\n    else\n        warn \"Skipping Git AI installation. You can install it later:\"\n        echo \"  curl -sSL https://usegitai.com/install.sh | bash\"\n    fi\nfi\n\n_run_git_ai_config() {\n    if command -v git-ai &>/dev/null; then\n        git-ai config set prompt_storage notes 2>/dev/null\n        git-ai install-hooks 2>/dev/null || true\n    elif [ -x \"$HOME/.git-ai/bin/git-ai\" ]; then\n        \"$HOME/.git-ai/bin/git-ai\" config set prompt_storage notes 2>/dev/null\n        \"$HOME/.git-ai/bin/git-ai\" install-hooks 2>/dev/null || true\n    elif git ai version &>/dev/null 2>&1; then\n        git ai config set prompt_storage notes 2>/dev/null\n        git ai install-hooks 2>/dev/null || true\n    fi\n}\nif _run_git_ai_config; then\n    info \"Git AI prompt_storage set to notes and hooks installed\"\nfi\n\n# ── Step 3: Install devmemory CLI via uv ───────────────────────────────────────\n\nstep \"[3/4] Installing devmemory CLI...\"\n\n# Install uv if not present\nif ! command -v uv &>/dev/null; then\n    echo \"Installing uv package manager...\"\n    curl -LsSf https://astral.sh/uv/install.sh | sh\n    # Source the env so uv is available immediately\n    export PATH=\"$HOME/.local/bin:$HOME/.cargo/bin:$PATH\"\n    if ! command -v uv &>/dev/null; then\n        error \"Failed to install uv. Install manually: https://docs.astral.sh/uv/getting-started/installation/\"\n        exit 1\n    fi\n    info \"uv installed\"\nelse\n    info \"uv $(uv --version | awk '{print $2}')\"\nfi\n\n# Install devmemory from PyPI\nuv tool install devmemory --force --quiet\nuv tool update-shell --quiet 2>/dev/null || true\ninfo \"devmemory installed\"\n\n# Ensure devmemory is on PATH for the rest of this script\nif ! command -v devmemory &>/dev/null; then\n    export PATH=\"$HOME/.local/bin:$PATH\"\nfi\n\nif ! command -v devmemory &>/dev/null; then\n    error \"devmemory not found on PATH after install.\"\n    echo \"  Try opening a new terminal, or run:\"\n    echo \"    export PATH=\\\"\\$HOME/.local/bin:\\$PATH\\\"\"\n    exit 1\nfi\ninfo \"devmemory is on PATH\"\n\n# ── Step 4: Configure git hooks ────────────────────────────────────────────────\n\nstep \"[4/4] Configuring git hooks...\"\n\nif git rev-parse --show-toplevel &>/dev/null; then\n    devmemory install --mode local\n    info \"Git hooks installed for attribution tracking\"\nelse\n    warn \"Not in a git repository. Run 'devmemory install --mode local' from a git repo to set up hooks.\"\nfi\n\necho \"\"\nstep \"Setup complete!\"\necho \"\"\necho \"Quick start:\"\necho \"  devmemory status         Check everything is working\"\necho \"  devmemory sync           Sync existing Git AI data\"\necho \"  devmemory attribution    View AI attribution\"\necho \"\"\necho \"LOCAL MODE (Free Forever):\"\necho \"  ✓ SQLite storage\"\necho \"  ✓ Core attribution\"\necho \"  ✓ Works offline\"\necho \"\"\necho \"CLOUD MODE (Advanced Features):\"\necho \"  Visit: https://devmemory.ai\"\necho \"  devmemory install --mode cloud --api-key YOUR_KEY\"\necho \"\"\necho \"Need help?\"\necho \"  Docs: https://github.com/AI-Provenance/ai-dev-memory\"\necho \"  Issues: https://github.com/AI-Provenance/ai-dev-memory/issues\"\n",
