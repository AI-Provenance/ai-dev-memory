mmit_sha, ex=DEPLOY_TTL)\n    \n    return DeploymentResponse(\n        repo_id=request.repo_id,\n        release=request.release,\n        commit_sha=request.commit_sha,\n        stored=True\n    )\n\n\n@app.get(\"/api/v1/deployments/{repo_id}/{release}\")\nasync def get_deployment(repo_id: str, release: str):\n    \"\"\"Get commit SHA for a release.\"\"\"\n    key = f\"deploy:{repo_id}:{release}\"\n    commit_sha = redis_client.get(key)\n    \n    if not commit_sha:\n        raise HTTPException(404, \"Release not found\")\n    \n    return {\"repo_id\": repo_id, \"release\": release, \"commit_sha\": commit_sha}\n```\n\n## Environment Variables\n\n| Variable | Required | Description |\n|----------|----------|-------------|\n| `REDIS_URL` | Yes | Redis connection URL |\n| `DEPLOY_TTL_SECONDS` | No | TTL for deployment mappings (default: 2592000 = 30 days) |\n\n## Usage\n\n### Store deployment (called by CI/CD)\n\n```bash\ncurl -X POST http://localhost:8000/api/v1/deployments \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"repo_id\": \"payments-service\",\n    \"release\": \"v2.3.1\",\n    \"commit_sha\": \"abc123def456789\"\n  }'\n\n# Response:\n# {\n#   \"repo_id\": \"payments-service\",\n#   \"release\": \"v2.3.1\",\n#   \"commit_sha\": \"abc123def456789\",\n#   \"stored\": true\n# }\n```\n\n### Get deployment\n\n```bash\ncurl http://localhost:8000/api/v1/deployments/payments-service/v2.3.1\n\n# Response:\n# {\n#   \"repo_id\": \"payments-service\",\n#   \"release\": \"v2.3.1\",\n#   \"commit_sha\": \"abc123def456789\"\n# }\n```\n\n## GitLab CI Integration\n\n```yaml\n# .gitlab-ci.yml\ndeploy:\n  stage: deploy\n  script:\n    # Store deployment mapping after successful deploy\n    - |\n      curl -X POST $AMS_API/api/v1/deployments \\\n        -H \"Content-Type: application/json\" \\\n        -d '{\n          \"repo_id\": \"$CI_PROJECT_NAME\",\n          \"release\": \"$CI_COMMIT_TAG\",\n          \"commit_sha\": \"$CI_COMMIT_SHA\"\n        }'\n  on