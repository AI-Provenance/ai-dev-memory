      start, end = map(int, range_str.split(\"-\"))\n            if start <= lineno <= end:\n                return json.loads(attr_json)\n        except (ValueError, json.JSONDecodeError):\n            continue\n    return None\n\n\n@app.post(\"/api/v1/attribution/lookup\", response_model=AttributionResponse)\nasync def lookup_attribution(request: AttributionRequest):\n    \"\"\"\n    Look up AI attribution for a specific line.\n    \n    Query: Just filepath + lineno (no release needed!)\n    Returns: Latest attribution for that line\n    \"\"\"\n    \n    # Step 1: Get latest commit for this file\n    latest_key = f\"attr_latest:{request.repo_id}:{request.filepath}\"\n    latest_commit = redis_client.get(latest_key)\n    \n    if latest_commit:\n        # Step 2: Get ranges for latest commit\n        attr_key = f\"attr:{request.repo_id}:{request.filepath}:{latest_commit}\"\n        ranges = redis_client.hgetall(attr_key)\n        \n        # Step 3: Find line in ranges\n        attr = find_line_in_ranges(ranges, request.lineno)\n        if attr:\n            return AttributionResponse(\n                author=attr.get(\"author\", \"unknown\"),\n                tool=attr.get(\"tool\"),\n                model=attr.get(\"model\"),\n                confidence=0.95 if attr.get(\"author\") == \"ai\" else 0.99,\n                commit_sha=latest_commit\n            )\n    \n    # Step 4: Fallback - check history (last N commits)\n    history_key = f\"attr_history:{request.repo_id}:{request.filepath}\"\n    commits = redis_client.zrevrange(history_key, 0, FALLBACK_DEPTH - 1)\n    \n    for commit_sha in commits:\n        attr_key = f\"attr:{request.repo_id}:{request.filepath}:{commit_sha}\"\n        ranges = redis_client.hgetall(attr_key)\n        attr = find_line_in_ranges(ranges, request.lineno)\n        \n        if attr:\n            return AttributionResponse(\n                author=attr.get(\"author\", \"unknown\"),\n                tool=attr.get(\"tool\"),\n     