OPENAI_API_KEY=your_openai_api_key_here

# Optional: override default models
# GENERATION_MODEL=gpt-5-mini
# EMBEDDING_MODEL=text-embedding-3-small

# Optional: use Anthropic instead of OpenAI for generation
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GENERATION_MODEL=claude-3-5-haiku-20241022

# Cloud API configuration (optional - for cloud sync and features)
# Get your API key at https://aiprove.org
# API_KEY=your_api_key_here
# API_URL=https://aiprove.org/api

# Local SQLite configuration (optional - for local attribution storage)
# Defaults to .devmemory/attributions.db in your repo
# SQLITE_PATH=.devmemory/attributions.db

